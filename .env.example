# ===== RewardHive Environment Variables =====
# Copy this file to .env and fill in your values
# On Vercel: add these in Settings → Environment Variables

# Database (SQLite for demo — use PostgreSQL/MySQL for production)
DATABASE_URL="file:./db/custom.db"

# NextAuth.js (generate a secret: run `openssl rand -base64 32` in terminal)
NEXTAUTH_SECRET="replace-with-random-32-char-string"
NEXTAUTH_URL="http://localhost:3000"

# App
NODE_ENV="development"
